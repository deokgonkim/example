{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hello World",
  "version": "0.1.0",
  "identifier": "com.example.helloworld",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hello World",
        "width": 900,
        "height": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
